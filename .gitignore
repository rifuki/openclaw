# macOS
.DS_Store

# Runtime / session data (changes too often, not useful to track)
agents/
canvas/
completions/
credentials/
devices/
identity/
logs/
update-check.json
cron/

# Workspace state
workspace/**/.openclaw/

# SQLite / db files
**/*.db
**/*.sqlite

# Config backups
*.bak
*.bak.*

# Sensitive
agents/*/agent/auth-profiles.json

# Workspace memory (daily logs — optional, uncomment to exclude)
# workspace/doloris/memory/
